# Default: normalize line endings to LF in the repo, checkout as-is on Windows
* text=auto eol=lf

# Source code — always LF
*.cs        text eol=lf
*.csproj    text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.sln       text eol=crlf
*.slnx      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.xml       text eol=lf
*.config    text eol=lf
*.sh        text eol=lf
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# Binary — never diff or mangle
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.nupkg     binary
*.snupkg    binary
*.dll       binary
*.exe       binary
*.pdb       binary
